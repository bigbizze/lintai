{
	"name": "lintai-workspace",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm -r build && go build ./cmd/lintai",
		"build:dist": "pnpm build && pnpm build:npm-binaries",
		"build:npm-binary:host": "node scripts/build-npm-binaries.mjs --host-only",
		"build:npm-binaries": "node scripts/build-npm-binaries.mjs",
		"check": "biome check .",
		"format": "biome format --write .",
		"publish:npm": "node scripts/publish-npm.mjs",
		"smoke:npm": "node scripts/smoke-npm-install.mjs",
		"test": "go test ./..."
	},
	"devDependencies": {
		"@types/node": "^22.15.21",
		"@biomejs/biome": "^1.9.0",
		"esbuild": "^0.25.2",
		"eslint": "^9.24.0",
		"typescript": "^5.7.0"
	},
	"dependencies": {
		"zod": "^3.24.2"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"esbuild"
		]
	},
	"packageManager": "pnpm@10.9.0+sha512.0486e394640d3c1fb3c9d43d49cf92879ff74f8516959c235308f5a8f62e2e19528a65cdc2a3058f587cde71eba3d5b56327c8c33a97e4c4051ca48a10ca2d5f"
}
