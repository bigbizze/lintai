{
	"name": "@lintai/eslint-plugin",
	"version": "0.1.2",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bigbizze/lintai.git",
		"directory": "packages/eslint-plugin"
	},
	"homepage": "https://github.com/bigbizze/lintai#readme",
	"bugs": {
		"url": "https://github.com/bigbizze/lintai/issues"
	},
	"files": [
		"dist",
		"scripts"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "node --test dist/**/*.test.js"
	},
	"dependencies": {
		"@lintai/authoring-rules": "workspace:*",
		"@lintai/sdk": "workspace:*",
		"chokidar": "^4.0.3",
		"esbuild": "^0.25.2"
	},
	"peerDependencies": {
		"eslint": "^9.24.0"
	},
	"peerDependenciesMeta": {
		"eslint": {
			"optional": true
		}
	},
	"devDependencies": {
		"eslint": "^9.24.0",
		"typescript": "^5.7.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
