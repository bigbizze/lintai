{
	"name": "@lintai/cli",
	"version": "0.1.3",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bigbizze/lintai.git",
		"directory": "packages/lintai"
	},
	"homepage": "https://github.com/bigbizze/lintai#readme",
	"bugs": {
		"url": "https://github.com/bigbizze/lintai/issues"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"lintai": "./dist/bin.js"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch"
	},
	"dependencies": {
		"@lintai/eslint-plugin": "workspace:*"
	},
	"optionalDependencies": {
		"@lintai/lintai-darwin-arm64": "workspace:*",
		"@lintai/lintai-darwin-x64": "workspace:*",
		"@lintai/lintai-linux-arm64": "workspace:*",
		"@lintai/lintai-linux-x64": "workspace:*"
	},
	"devDependencies": {
		"typescript": "^5.7.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
