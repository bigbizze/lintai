{
	"name": "lintai",
	"version": "0.1.0",
	"type": "module",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"bin": {
		"lintai": "./dist/bin.js"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch"
	},
	"dependencies": {
		"@lintai/eslint-plugin": "workspace:*"
	},
	"optionalDependencies": {
		"@lintai/lintai-darwin-arm64": "workspace:*",
		"@lintai/lintai-darwin-x64": "workspace:*",
		"@lintai/lintai-linux-arm64": "workspace:*",
		"@lintai/lintai-linux-x64": "workspace:*"
	},
	"devDependencies": {
		"typescript": "^5.7.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
